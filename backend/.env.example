# Twilio Configuration (Optional - for SMS alerts)
# Sign up at https://www.twilio.com to get these credentials

TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1234567890

# Note: Without these credentials, alerts will be logged to console
# This is perfectly fine for hackathon demos!
